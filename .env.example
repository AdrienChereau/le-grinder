# ── Le Grinder — configuration (tout est optionnel, défauts sûrs) ──────────

# Stratégie
GRIND_BASE=1.0          # mise de départ $ (et valeur de reset après wipe)
ENTRY_MIN=0.95          # prix minimal du favori pour entrer
ENTRY_MAX=0.99          # au-delà, le gain restant ne paie plus le risque
Z_ENTRY=1.5             # marge z (spot vs strike / vol×√t) exigée pour ENTRER
Z_EXIT=0.5              # marge z sous laquelle on vend en CATASTROPHE
DRIFT_EXIT=0.00003      # drift log/s à contre-sens déclenchant la sortie (échelle 1e-5)
MIN_REMAINING_S=15      # pas d'entrée s'il reste moins (pas le temps de sortir)
MAX_REMAINING_S=240     # pas d'entrée s'il reste plus (95c trop tôt = suspect)

# Simulation paper
PANIC_HAIRCUT=0.5       # fraction de la profondeur bid encore là pendant un crash
TAKER_FEE_RATE=0.07     # frais taker : rate × p(1−p) × parts (à trancher au 1er fill live)
BOOK_MAX_AGE_MS=5000    # âge max du carnet WS avant fallback REST

# Garde Tokyo (locale)
DRIFT_HALFLIFE_S=25
VOL_WINDOW_MS=2000
VOL_FLOOR=0.30
OBI_DEPTH_LEVELS=10
OBI_THRESHOLD=0.8
VELOCITY_THRESHOLD=45   # $/s — leçon du paper monolith
KILL_LATCH_MS=5000      # un KILL reste actif 5 s (anti-rebond)
GUARD_MAX_AGE_MS=3000   # flux Binance plus vieux → garde aveugle, pas d'entrée

# Infra
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@depth20@100ms
DASH_BIND=0.0.0.0       # dashboards consultés via Tailscale
DASH_PORT=8095
STATE_PATH=data/grinder_state.json
WINDOWS_PATH=data/grinder_windows.jsonl
RUST_LOG=info
